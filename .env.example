# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (for AI lead generation)
OPENAI_API_KEY=your-openai-api-key
LEADS_MAX_PER_USER=10
LEADS_MIN_TARGET_PER_USER=5
LEADS_DISCOVERY_LOOKBACK_DAYS=3
LEADS_DISCOVERY_MAX_ARTICLES=30
LEADS_DISCOVERY_MODEL=gpt-4o-mini
LEADS_DISCOVERY_DUPLICATE_WINDOW_DAYS=60
LEADS_DISCOVERY_INCLUDE_NEWSAPI=true
LEADS_DISCOVERY_INCLUDE_GOOGLE_RSS=true
LEADS_DISCOVERY_HEURISTIC_FALLBACK_LIMIT=8
LEADS_DEBUG=false

# News API (for company news monitoring)
NEWSAPI_KEY=your-newsapi-key

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Outlook Calendar (read-only sync)
# Option A (quick test): use a short-lived access token
OUTLOOK_ACCESS_TOKEN=
# Option B (recommended): automatic refresh flow
# Use "common" for personal Microsoft accounts (Hotmail/Outlook.com).
# Use tenant GUID for Entra work/school accounts.
OUTLOOK_TENANT_ID=common
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=
# Optional: use /users/{OUTLOOK_USER_ID}/calendarView instead of /me/calendarView
OUTLOOK_USER_ID=

# Database (for Prisma / migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# RapidAPI - Company -> People -> Leads (companyPeopleToLeads.js)
RAPIDAPI_KEYS=
RAPIDAPI_KEY_1=
RAPIDAPI_KEY_2=
RAPIDAPI_KEY_3=
RAPIDAPI_KEY_4=
RAPIDAPI_KEY_5=
RAPIDAPI_KEY_6=
RAPIDAPI_KEY_7=
RAPIDAPI_KEY_8=
RAPIDAPI_KEY_9=
RAPIDAPI_KEY_10=
RAPIDAPI_KEY_11=
RAPIDAPI_KEY_12=
RAPIDAPI_KEY_13=
RAPIDAPI_KEY_14=
RAPIDAPI_KEY_15=
RAPIDAPI_KEY_16=
RAPIDAPI_KEY_17=
RAPIDAPI_KEY_18=
RAPIDAPI_KEY_19=
RAPIDAPI_KEY_20=
RAPIDAPI_TIMEOUT_MS=30000
RAPIDAPI_MAX_RETRIES=2
COMPANY_SEARCH_MAX_PAGES=5
COMPANY_PEOPLE_MAX_CANDIDATES=6
COMPANY_PEOPLE_CANDIDATE_TIMEOUT_MS=240000
HTTP_FETCH_TIMEOUT_MS=20000
PEOPLE_MAX_PAGES=200
PEOPLE_MAX_TOTAL=1500
PEOPLE_MIN_PAGES_BEFORE_EARLY_STOP=20
PEOPLE_TARGET_DECISION_MAKERS=4
PEOPLE_DEBUG_SAVE_RAW_PAGES=false
SHORTLIST_LIMIT=15
STRICT_SWEDEN_ONLY=true
