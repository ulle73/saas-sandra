generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id      String @id @default(uuid())
  email   String @unique
  @@ignore
}

model Company {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  name         String
  industry     String?
  website      String?
  newsKeywordIds String[]  @map("news_keyword_ids")
  newsCustomKeywords String[] @map("news_custom_keywords")
  newsKeywords String[]    @map("news_keywords")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  contacts     Contact[]
  newsItems    NewsItem[]
  weeklyLeads  WeeklyLead[]

  @@map("companies")
}

model Contact {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  companyId     String?      @map("company_id") @db.Uuid
  name          String
  email         String?
  phone         String?
  linkedinUrl   String?      @map("linkedin_url")
  lastTouchpoint DateTime?   @map("last_touchpoint") @db.Timestamptz(6)
  nextActivity  DateTime?    @map("next_activity") @db.Timestamptz(6)
  status        String       @default("red")
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  company       Company?     @relation(fields: [companyId], references: [id])
  activities    Activity[]
  weeklyLeads   WeeklyLead[]

  @@map("contacts")
}

model Activity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  type      String
  notes     String?
  timestamp DateTime @default(now()) @db.Timestamptz(6)
  outcome   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  contact   Contact  @relation(fields: [contactId], references: [id])

  @@map("activities")
}

model NewsItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  title       String
  url         String
  source      String?
  newsType    String?  @map("news_type")
  isRelevant  Boolean  @default(true) @map("is_relevant")
  matchedKeyword String? @map("matched_keyword")
  publishedAt DateTime @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  company     Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, url])
  @@map("news_items")
}

model WeeklyLead {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  contactId   String?  @map("contact_id") @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  reason      String
  pitch       String
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  contact     Contact? @relation(fields: [contactId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id])

  @@map("weekly_leads")
}
